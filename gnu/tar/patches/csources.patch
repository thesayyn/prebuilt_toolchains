+# define _GL_STATIC_ASSERT_TYPE(R, DIAGNOSTIC) \
+    struct {                                   \
+      _Static_assert (R, DIAGNOSTIC);          \
+      int _gl_dummy;                          \
+    }
+#else
+# define _GL_STATIC_ASSERT_TYPE(R, DIAGNOSTIC) \
+    struct { unsigned int _gl_static_assert_error_if_negative: (R) ? 1 : -1; }
+#endif
